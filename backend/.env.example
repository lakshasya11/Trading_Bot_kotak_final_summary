# Trading Bot Environment Variables
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to git!

# User 1 Credentials
USER1_NAME=User1
USER1_API_KEY=your_api_key_here
USER1_API_SECRET=your_api_secret_here
USER1_DESCRIPTION=Primary account

# User 2 Credentials
USER2_NAME=User2
USER2_API_KEY=your_api_key_here
USER2_API_SECRET=your_api_secret_here
USER2_DESCRIPTION=Secondary account

# User 3 Credentials
USER3_NAME=User3
USER3_API_KEY=your_api_key_here
USER3_API_SECRET=your_api_secret_here
USER3_DESCRIPTION=Third account

# Active User (user1, user2, or user3)
ACTIVE_USER=user1

# Central DB server (PC2)
CENTRAL_API_URL=http://<PC2_IP>:5004
API_KEY=
